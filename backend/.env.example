# このファイルをコピーして backend/.env を作成し、値を埋めてください:
#   cp backend/.env.example backend/.env
#
# Docker Compose で起動する場合、DATABASE_URL は docker-compose.yml の
# environment で自動的に host=db に上書きされるため、下の localhost 版のままでOK。
# ローカル（非Docker/XAMPP）で起動する場合はこの DATABASE_URL がそのまま使われる。
DATABASE_URL="mysql+pymysql://root:@localhost:3306/mytechpulse"

# Qiita のアクセストークン（https://qiita.com/settings/applications で発行）
QIITA_ACCESS_TOKEN="ここにQiitaアクセストークンを入れる"

# JWT署名鍵。未設定だと起動に失敗する。以下のコマンドで生成したランダム文字列を設定する:
#   python -c "import secrets; print(secrets.token_hex(32))"
# 本番用の値は開発用と必ず別のものを新規生成すること
SECRET_KEY="ここに生成したランダム文字列を入れる"

# CORS追加許可オリジン（カンマ区切り・任意）。本番フロントエンドのURLを足す場合に使う
# 例: CORS_ALLOWED_ORIGINS="https://mytechpulse.example.com"
# CORS_ALLOWED_ORIGINS=

# SQLログを出力したい場合のみ true にする（本番ではfalse推奨・デフォルトfalse）
# DB_ECHO=true
